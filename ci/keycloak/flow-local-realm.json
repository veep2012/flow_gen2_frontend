{
  "realm": "flow-local",
  "enabled": true,
  "displayName": "Flow Local",
  "sslRequired": "external",
  "registrationAllowed": false,
  "passwordPolicy": "hashAlgorithm(argon2)",
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging"],
  "eventsExpiration": 604800,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": false,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 300,
  "maxFailureWaitSeconds": 1800,
  "minimumQuickLoginWaitSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "permanentLockout": false,
  "clients": [
    {
      "clientId": "flow-ui",
      "name": "Flow UI",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost"
      ]
    },
    {
      "clientId": "flow-oauth2-proxy",
      "name": "Flow oauth2-proxy",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "change_me_now",
      "redirectUris": [
        "http://localhost/oauth2/callback"
      ],
      "webOrigins": [
        "http://localhost"
      ],
      "protocolMappers": [
        {
          "name": "acronym claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "acronym",
            "claim.name": "acronym",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "preferred_username from acronym",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "acronym",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience flow-oauth2-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "flow-oauth2-proxy",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@local",
      "attributes": {
        "acronym": [
          "ZAML"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "TestUser!2345",
          "temporary": false
        }
      ]
    }
  ]
}
